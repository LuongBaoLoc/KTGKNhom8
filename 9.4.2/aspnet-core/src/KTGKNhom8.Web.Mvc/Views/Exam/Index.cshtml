@model List<KTGKNhom8.ToeicExams.Dto.ExamListItemDto>

@{
    ViewBag.Title = "Danh Sách Đề Thi TOEIC";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-list"></i> Danh Sách Đề Thi TOEIC</h2>
                <a href="@Url.Action("Upload")" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Tải Lên Đề Thi
                </a>
            </div>

            @if (Model == null || Model.Count == 0)
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> Chưa có đề thi nào. 
                    <a href="@Url.Action("Upload")">Tải lên đề thi</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Tên Đề Thi</th>
                                <th>Số Câu Hỏi</th>
                                <th>Thời Gian (Phút)</th>
                                <th>Mô Tả</th>
                                <th>Hành Động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exam in Model)
                            {
                                <tr>
                                    <td>@exam.Id</td>
                                    <td><strong>@exam.Title</strong></td>
                                    <td><span class="badge badge-info">@exam.TotalQuestions</span></td>
                                    <td>@exam.TimeLimit</td>
                                    <td>@exam.Description</td>
                                    <td>
                                        <a href="@Url.Action("TakeExam", new { id = exam.Id })" class="btn btn-sm btn-success">
                                            <i class="fas fa-play"></i> Làm Bài
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
