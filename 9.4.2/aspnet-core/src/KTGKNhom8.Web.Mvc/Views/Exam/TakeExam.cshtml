@model KTGKNhom8.ToeicExams.Dto.ExamDetailDto

@{
    ViewBag.Title = Model.Title;
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4><i class="fas fa-book"></i> @Model.Title</h4>
                    <p class="mb-0">Thời gian làm bài: <strong>@Model.TimeLimit phút</strong> | Số câu hỏi: <strong>@Model.Parts.Sum(p => p.Questions.Count)</strong></p>
                </div>
                <div class="card-body">
                    <form asp-controller="Exam" asp-action="SubmitExam" method="post" id="examForm">
                        <input type="hidden" name="ExamId" value="@Model.Id" />
                        <input type="hidden" name="TimeSpent" id="timeSpent" />

                        @foreach (var part in Model.Parts)
                        {
                            <div class="mb-4">
                                <h5 class="border-bottom pb-2"><i class="fas fa-layer-group"></i> Part @part.PartType</h5>
                                
                                @foreach (var question in part.Questions)
                                {
                                    <div class="card mb-3 border-left-primary">
                                        <div class="card-body">
                                            <div class="mb-3">
                                                <strong>Câu @question.QuestionNumber:</strong> @question.Content
                                            </div>
                                            
                                            <div class="ml-3">
                                                @foreach (var answer in question.Answers)
                                                {
                                                    <div class="custom-control custom-radio mb-2">
                                                        <input type="radio" 
                                                               class="custom-control-input" 
                                                               id="q@(question.Id)_@(answer.Id)" 
                                                               name="Answers[@(question.Id)]" 
                                                               value="@(answer.Id)"
                                                               data-question-id="@(question.Id)"
                                                               data-answer-id="@(answer.Id)" />
                                                        <label class="custom-control-label" for="q@(question.Id)_@(answer.Id)">
                                                            <strong>@answer.Label.</strong> @answer.Content
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="form-group text-center mt-4">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="fas fa-check"></i> Nộp Bài
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg ml-2">
                                <i class="fas fa-times"></i> Hủy
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let startTime = new Date();
    document.getElementById('examForm').addEventListener('submit', function() {
        let endTime = new Date();
        let timeSpent = Math.floor((endTime - startTime) / 1000 / 60);
        document.getElementById('timeSpent').value = timeSpent;
    });
</script>
